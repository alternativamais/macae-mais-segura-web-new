{
  "name": "shadcn-dashboard-nextjs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "next dev --port 3001",
    "build": "next build && find .next -type f -name '*.map' -delete",
    "start": "next start --hostname 0.0.0.0 --port 3001",
    "start:prod": "next start --hostname 0.0.0.0 --port 3001",
    "lint": "next lint",
    "i18n:check": "node ./scripts/check-i18n.mjs",
    "log:web": "docker logs -f alternativa-macaemaissegura-frontend",
    "docker:up": "sudo docker rm -f alternativa-macaemaissegura-frontend >/dev/null 2>&1 || true && sudo docker run -d --name alternativa-macaemaissegura-frontend --restart unless-stopped --network macae_rede --env-file ./.env -p 127.0.0.1:3001:3001 alternativa-macaemaissegura-frontend",
    "docker:down": "sudo docker rm -f alternativa-macaemaissegura-frontend >/dev/null 2>&1 || true",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "docker:build": "sudo docker build -t alternativa-macaemaissegura-frontend . && npm run docker:up",
    "docker:build:web": "sudo docker build -t alternativa-macaemaissegura-frontend . && npm run docker:up",
    "docker:logs": "sudo docker logs -f --tail 100 alternativa-macaemaissegura-frontend",
    "docker:logs:web": "sudo docker logs -f --tail 100 alternativa-macaemaissegura-frontend",
    "docker:shell": "sudo docker exec -it alternativa-macaemaissegura-frontend /bin/sh",
    "docker:shell:web": "sudo docker exec -it alternativa-macaemaissegura-frontend /bin/sh"
  },
  "overrides": {
    "follow-redirects": "^1.16.0",
    "picomatch": "^4.0.4"
  },
